# Exemplo de variáveis para testar o notificador LOCALMENTE.
# Copia para um ficheiro ".env" (que NÃO é versionado) e preenche.
# Em produção, estes valores ficam nos Secrets do GitHub Actions (não aqui).

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=cole_aqui_a_chave_service_role
TELEGRAM_BOT_TOKEN=123456789:cole_aqui_o_token_do_BotFather
TELEGRAM_CHAT_ID=cole_aqui_o_teu_chat_id

# DRY_RUN=1   # opcional: imprime as mensagens em vez de as enviar
